APP_NAME=telemedconsult.md
APP_ENV=production
APP_KEY=base64:GENEREAZA_O_CHEIE_LARAVEL
APP_DEBUG=false
APP_URL=https://telemedconsult.md
FRONTEND_URL=https://telemedconsult.md

LOG_CHANNEL=stderr
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=telemedconsult
DB_USERNAME=telemedconsult
DB_PASSWORD=SCHIMBA_CU_O_PAROLA_PUTERNICA

# Variabilele MYSQL_* sunt folosite la inițializarea containerului MySQL.
# MYSQL_DATABASE/USER/PASSWORD trebuie să corespundă cu DB_DATABASE/USERNAME/PASSWORD.
MYSQL_DATABASE=telemedconsult
MYSQL_USER=telemedconsult
MYSQL_PASSWORD=SCHIMBA_CU_O_PAROLA_PUTERNICA
MYSQL_ROOT_PASSWORD=SCHIMBA_CU_ALTA_PAROLA_PUTERNICA

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=SCHIMBA_CU_O_PAROLA_REDIS_PUTERNICA

CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local

REVERB_APP_ID=telemedconsult
REVERB_APP_KEY=SCHIMBA_CU_O_CHEIE_REVERB
REVERB_APP_SECRET=SCHIMBA_CU_UN_SECRET_REVERB
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

RUN_SEEDERS=false
OTP_DEMO_CODE_ENABLED=false
OTP_EXPIRES_MINUTES=10

MAIL_MAILER=resend
RESEND_API_KEY=INTRODU_CHEIA_API_RESEND
MAIL_FROM_ADDRESS=no-reply@notify.telemedconsult.md
MAIL_FROM_NAME=telemedconsult.md

MAIB_PROJECT_ID=
MAIB_PROJECT_SECRET=
MAIB_SIGNATURE_KEY=
MAIB_OK_URL=https://telemedconsult.md/api/v1/payments/maib/ok
MAIB_CALLBACK_URL=https://telemedconsult.md/api/v1/payments/callback/maib
MAIB_FAIL_URL=https://telemedconsult.md/api/v1/payments/maib/fail

HIGO_BASE_URL=
HIGO_CLIENT_ID=
HIGO_CLIENT_SECRET=
HIGO_USERNAME=
HIGO_PASSWORD=
HIGO_OAUTH_TOKEN_PATH=/oauth/token
HIGO_CACHE_STORE=redis
HIGO_REQUIRE_SHARED_LOCK_STORE=true

# Configurația imaginii oficiale phpMyAdmin.
PMA_HOST=mysql
PMA_PORT=3306
UPLOAD_LIMIT=64M
MEMORY_LIMIT=512M
MAX_EXECUTION_TIME=600
